{
  "name": "docker-node-app",
  "version": "3.0.0",
  "description": "Node.js on Docker",
  "repository": "https://github.com/jonfairbanks/docker-node-app.git",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch --inspect=0.0.0.0:9229 index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test",
    "test:watch": "node --test --watch"
  },
  "engines": {
    "node": ">=22.13 <25",
    "npm": ">=10"
  },
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "dayjs": "^1.11.21",
    "ejs": "^6.0.1",
    "express": "^5.2.1"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "supertest": "^7.2.2"
  }
}
